// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"  // No Prisma 7, use "prisma-client"
  output       = "../src/generated/prisma" // Salva dentro do código do Nest
  moduleFormat = "cjs"            // Força o formato CommonJS compatível com o Nest
}

datasource db {
  provider = "postgresql"
}


model Usuario {
  // id será único para cada e sempre será incrementado
  // uuid gera um id unico e aleatorio
  id              String          @id @default(uuid())
  // um email só pode ter uma conta e é obrigatório
  email           String          @unique
  // nome é obrigatório
  nome            String
  // senha é obrigatória
  senha           String
  // Papel do usuário
  papel           String          @default("EXTERNO")
  // Data que foi criado pega a data atual
  createdAt       DateTime        @default(now())
  // Data de atualização
  updatedAt       DateTime        @updatedAt
}

model Convite {
  id              String          @id @default(uuid())
  codigo          String          @unique
  papel           String          @default("EXTERNO")
  usado           Boolean         @default(false)
  createdAt       DateTime        @default(now())
}